# Salin ke C:\Seosementara\.env (production mini PC)
# PowerShell: Copy-Item mini-pc\env.example C:\Seosementara\.env
#
# Dev lokal: salin ke .env di root repo, uncomment bagian DEV di bawah.
# Isi nilai production — lihat mini-pc/env.production (file lokal, tidak di Git).

# --- Database ---
DB_PASSWORD=

# --- Enkripsi & auth ---
MASTER_ENCRYPTION_KEY=
PIXEL_ENCRYPTION_KEY=
SUPER_ADMIN_TOKEN=

# --- Cloudflare (Global API Key — referensi; deploy Workers via GitHub Secrets) ---
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCOUNT_EMAIL=
CLOUDFLARE_TUNNEL_ID=

# --- Domain ---
PRIMARY_DOMAIN=apidevel.org
APEX_URL=https://apidevel.org
API_BASE_URL=https://api.apidevel.org
ENVIRONMENT=production

# --- DEV lokal (docker-compose.yml) — uncomment jika develop di laptop ---
# DATABASE_URL=postgres://seosementara:changeme@localhost:5432/seosementara?sslmode=disable
# ALLOW_SETUP_WITHOUT_AUTH=false
# ADDR=:8080
# ADMIN_PARTIALS_DIR=../Frontend-admin/public/admin/_partials
# STATIC_DIR=../Frontend-admin/static
# ADMIN_TEMPLATES_DIR=../Frontend-admin/templates
