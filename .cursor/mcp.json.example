{
  "mcpServers": {
    "seosementara-mini-pc": {
      "command": "node",
      "args": ["mcp/mini-pc-remote/src/index.js"],
      "env": {
        "MINI_PC_SSH_HOST": "GANTI.tailxxxxx.ts.net",
        "MINI_PC_SSH_USER": "Administrator",
        "MINI_PC_SSH_KEY_PATH": "/path/to/your/private_key"
      }
    }
  }
}
